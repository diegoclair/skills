{{- /*
  list.html.tmpl — Slide layout: NUMBERED LIST
  ---------------------------------------------
  Fields used:
    .Slide.Title  string   — slide title, 64px bold (optional but recommended)
    .Slide.Items  []string — list items, ≤5 per slide (L1)

  Spec rules (D §4 List):
    L1: items_per_slide <= 5
    L2: badge 48–60px with item number (we use 56×56px)
    L3: item_font_size >= 36px
    L4: gap_between_items >= 24px (we use 32px)

  Layout: title at top → numbered badges + text list below.
  Badge: circular, background=accent, number centered.
*/ -}}
{{define "layout-list"}}
{{- $count := len .Slide.Items -}}
<style>
  /* Center the list block vertically so short lists don't leave half the
     canvas empty below. Title pinned to top, then items grow into the
     remaining space and stay centered. */
  .list-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-bottom: 96px;
    gap: 48px;
  }

  .list-title {
    font-family: var(--font-heading);
    font-size: 64px;
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.01em;
    color: var(--fg-primary);
    max-width: 900px;
  }

  .list-items {
    display: flex;
    flex-direction: column;
    gap: 32px;                  /* L4: gap >= 24px */
    list-style: none;
  }

  /* Item font scales with item count so short lists fill more vertical
     space without crowding longer ones. */
  .list-items[data-count="1"] .list-item__text,
  .list-items[data-count="2"] .list-item__text { font-size: 56px; }
  .list-items[data-count="3"] .list-item__text { font-size: 52px; }
  .list-items[data-count="4"] .list-item__text { font-size: 48px; }
  .list-items[data-count="5"] .list-item__text { font-size: 44px; }

  .list-item {
    display: flex;
    align-items: flex-start;
    gap: 28px;
  }

  .list-item__badge {
    flex-shrink: 0;
    width: 56px;                /* L2: 48–60px */
    height: 56px;
    border-radius: 50%;
    background-color: var(--accent);
    color: #fff;
    font-family: var(--font-heading);
    font-size: 24px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    letter-spacing: 0;
    line-height: 1;
    margin-top: 4px;            /* optical alignment with first line of text */
  }

  .list-item__text {
    font-family: var(--font-body);
    font-size: 44px;            /* Research E §5: 36→44 (mobile ~15pt). L3 floor: 36px. */
    font-weight: 500;
    line-height: 1.3;
    color: var(--fg-primary);
    max-width: 820px;
  }

  /* Optional divider line between items */
  .list-item + .list-item {
    padding-top: 8px;
    border-top: 1px solid rgba(128, 128, 128, 0.15);
  }
</style>

<div class="list-content">
  {{- if .Slide.Title }}
  <h2 class="list-title">{{ highlight .Slide.Title }}</h2>
  {{- end }}

  <ul class="list-items" data-count="{{ $count }}">
    {{- range $i, $item := .Slide.Items }}
    <li class="list-item">
      <span class="list-item__badge">{{ printf "%02d" (add1 $i) }}</span>
      <span class="list-item__text">{{ highlight $item }}</span>
    </li>
    {{- end }}
  </ul>
</div>

{{template "footer" .}}
{{end}}
