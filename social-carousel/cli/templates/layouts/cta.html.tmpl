{{- /*
  cta.html.tmpl — Slide layout: CALL TO ACTION (last slide)
  ----------------------------------------------------------
  Fields used:
    .Slide.Headline  string — question or command, ≤12 words (A5)
    .Slide.CTAText   string — specific action text (A2)
    .Slide.SwipeBack bool   — show "← Back to start" (A3)

  Spec rules (D §4 CTA):
    A1: cta_count = 1 (single CTA box)
    A2: cta_verb_specific (not "Follow me")
    A3: swipe_back_indicator_present
    A4: handle_and_logo_visible (handled by footer)
    A5: headline_words <= 12

  Layout: headline top-center → CTA box center → swipe-back below.
  CTA box: background=accent, padding 24×40, border-radius 16px, white bold text.
*/ -}}
{{define "layout-cta"}}
{{- $hw := wordCount .Slide.Headline -}}
{{- $headTier := "long" -}}
{{- if le $hw 5 -}}{{- $headTier = "poster" -}}
{{- else if le $hw 9 -}}{{- $headTier = "medium" -}}
{{- end -}}
{{- $cw := wordCount .Slide.CTAText -}}
<style>
  .cta-wrapper {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    gap: 48px;
    padding-bottom: var(--footer-reserve, 120px);
  }

  .cta-headline {
    font-family: var(--font-heading);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--fg-primary);
    max-width: 900px;
  }
  .cta-headline--poster { font-size: 120px; }
  .cta-headline--medium { font-size: 96px;  }
  .cta-headline--long   { font-size: 72px; line-height: 1.15; }

  .cta-box {
    display: inline-block;
    background-color: var(--accent);
    color: #fff;
    font-family: var(--font-heading);
    font-weight: 700;
    line-height: 1.2;
    padding: 24px 40px;
    border-radius: 16px;
    letter-spacing: 0.01em;
    box-shadow: 4px 4px 0px rgba(0,0,0,0.15);
    max-width: 820px;
  }
  /* Scale CTA-box text with the action copy length so "Save" doesn't dwarf
     "Comenta 'carousel' que te mando o link". */
  .cta-box--poster { font-size: 52px; }
  .cta-box--medium { font-size: 40px; }
  .cta-box--compact { font-size: 32px; }

  .cta-swipe-back {
    font-family: var(--font-body);
    font-size: 28px;
    font-weight: 400;
    line-height: 1.3;
    color: var(--fg-secondary);
    opacity: 0.5;
    letter-spacing: 0.01em;
  }
</style>

<div class="cta-wrapper">
  {{- if .Slide.Headline }}
  <h2 class="cta-headline cta-headline--{{ $headTier }}">{{ highlight .Slide.Headline }}</h2>
  {{- end }}

  {{- /* The CTA box already owns the accent (background fill). Strip
       **emphasis** from cta_text so we don't double-paint. Headline above
       can still use highlight — it's the secondary layer. */ -}}
  {{- if .Slide.CTAText }}
  <div class="cta-box cta-box--{{ if le $cw 4 }}poster{{ else if le $cw 8 }}medium{{ else }}compact{{ end }}">{{ plain .Slide.CTAText }}</div>
  {{- end }}

  {{- if .Slide.SwipeBack }}
  <p class="cta-swipe-back">← Volta pro início</p>
  {{- end }}
</div>

{{template "footer" .}}
{{end}}
