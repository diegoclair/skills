{{- /*
  big-number.html.tmpl — Slide layout: BIG NUMBER
  -------------------------------------------------
  Fields used:
    .Slide.Subhead string — small uppercase eyebrow ABOVE the number, ≤6 words.
                            Use when the number alone is ambiguous ("25 MIN"
                            of what?). Renders 28px, opacity 0.7, letterspaced.
    .Slide.Number  string — the number/stat, e.g. "87%" or "3×"
    .Slide.Caption string — short punchline ≤6 words (the number does the
                            headline work). Renders 40-56px depending on length.
    .Slide.Context string — optional explanatory line BELOW the caption, up
                            to 20 words. Renders 32px, max-width 820px.

  Composition: subhead (optional, label) → number (the protagonist) → caption
  (punchline) → context (explainer). Each is optional except number; the
  layout collapses gracefully when slots are empty.

  The caption + context tier scales with caption word count so a 4-word zinger
  reads as poster and a 12-word setup-line breathes properly.

  Markdown-style **emphasis** in caption/context renders in the accent color.
*/ -}}
{{define "layout-big-number"}}
{{- $captionWords := wordCount .Slide.Caption -}}
{{- $captionTier := "compact" -}}
{{- if le $captionWords 6 -}}{{- $captionTier = "poster" -}}
{{- else if le $captionWords 12 -}}{{- $captionTier = "medium" -}}
{{- end -}}
<style>
  .bignumber-wrapper {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding-bottom: var(--footer-reserve, 96px);
    gap: 24px;
  }

  .bignumber-subhead {
    font-family: var(--font-body);
    font-size: 28px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fg-secondary);
    opacity: 0.85;
    max-width: 820px;
    margin: 0;
  }

  .bignumber-number {
    font-family: var(--font-heading);
    font-size: 220px;           /* N1: >= 160px; 220px gives impact */
    font-weight: 900;
    line-height: 0.9;
    letter-spacing: -0.04em;
    color: var(--accent);
    word-break: break-word;
    margin: 0;
  }

  .bignumber-caption {
    font-family: var(--font-body);
    font-weight: 500;
    line-height: 1.3;
    color: var(--fg-primary);
    max-width: 820px;
    margin: 0;
  }
  .bignumber-caption--poster { font-size: 56px; font-weight: 600; }
  .bignumber-caption--medium { font-size: 44px; }
  .bignumber-caption--compact { font-size: 36px; }

  .bignumber-context {
    font-family: var(--font-body);
    font-size: 30px;
    font-weight: 400;
    line-height: 1.4;
    color: var(--fg-secondary);
    opacity: 0.95;
    max-width: 820px;
    margin-top: 8px;
  }
</style>

<div class="bignumber-wrapper">
  {{- if .Slide.Subhead }}
  <p class="bignumber-subhead">{{ .Slide.Subhead }}</p>
  {{- end }}

  <span class="bignumber-number">{{ .Slide.Number }}</span>

  {{- /* Accent budget: the number is already the accent role on this slide.
       Caption strips **emphasis** to plain text so we don't end up with two
       accent fields competing. Context keeps highlight only because it's
       a secondary layer where one stressed phrase still reads cleanly. */ -}}
  {{- if .Slide.Caption }}
  <p class="bignumber-caption bignumber-caption--{{ $captionTier }}">{{ plain .Slide.Caption }}</p>
  {{- end }}

  {{- if .Slide.Context }}
  <p class="bignumber-context">{{ highlight .Slide.Context }}</p>
  {{- end }}
</div>

{{template "footer" .}}
{{end}}
