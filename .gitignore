# ============================================================
# Go
# ============================================================
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Coverage output
*.out
coverage.out
coverage.html

# Go workspace file — committed in this repo.
# This is a multi-module monorepo (pkg/atlassian + confluence-docs/cli +
# future jira-tickets/cli); contributors need a shared workspace so IDE/LSP
# resolves the local shared lib without re-running `go work init`. The
# default Go template ignores go.work because it's the right call for
# single-module repos; for monorepos like this one, committing is the
# convention.

# Dependency directories
vendor/

# Build output
/bin/
/dist/
/build/
*/cli/bin/
*/cli/dist/
# Skill-root bin/ (some skills install via `make install-local` and produce
# the binary at <skill>/bin/<skill> instead of <skill>/cli/bin/<skill>).
*/bin/
release-assets/

# Fonts are downloaded by `make fonts` and embedded into the binary at
# build time via go:embed. They are NOT source — release CI re-downloads
# them before cross-compiling, so contributors run `make fonts` once and
# from then on `make build` reuses them. Excluding here keeps git diffs
# clean and avoids 12 MB of binary churn in PRs.
social-carousel/cli/templates/fonts/*.woff2
social-carousel/cli/templates/fonts/*.ttf

# ============================================================
# macOS
# ============================================================
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*
.Spotlight-V100
.Trashes

# ============================================================
# Windows
# ============================================================
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# ============================================================
# Linux
# ============================================================
*~
.fuse_hidden*
.directory
.Trash-*

# ============================================================
# IDEs / Editors
# ============================================================
.vscode/
.idea/
*.swp
*.swo
*.iml
.project
.classpath
.settings/
*.sublime-workspace
*.sublime-project

# ============================================================
# Environment / secrets
# ============================================================
.env
.env.local
.env.*.local
*.pem
*.key
secrets.json

# ============================================================
# Logs & temp
# ============================================================
*.log
logs/
tmp/
temp/
.cache/

# ============================================================
# Node (if any tooling is added later)
# ============================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Stray binaries from `go build ./...` run inside any <skill>/cli/.
# (Go names the binary after the package directory; we want it in bin/.)
*/cli/cli
*/cli/cli.exe
